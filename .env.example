# Shared environment
# APP_ENV may be development, production, or test.
APP_ENV=development

# PostgreSQL
# Required for the web app in production and required in practice to run the worker.
DATABASE_URL=URL for connecting to the PostgreSQL database. For example:
# with SSL enabled.
DB_SSL=disable
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=10000

# Google provider
# GOOGLE_PLACES_API_KEY is required in production for both web and worker.
GOOGLE_PLACES_API_KEY=replace-me
# If empty, the worker falls back to GOOGLE_PLACES_API_KEY for Geocoding.
GOOGLE_GEOCODING_API_KEY=
GOOGLE_REQUEST_TIMEOUT_SECONDS=10
GOOGLE_DAILY_REQUEST_LIMIT=1000
# Local quota state file. On ephemeral filesystems this state may reset.
GOOGLE_QUOTA_STATE_PATH=.worker-state/google-api-quota.json

# Shared pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL=info

# Web runtime
# Empty means same-origin only. Set a comma-separated allowlist only if a
# separate origin must call the API routes.
ALLOWED_ORIGINS=
API_JSON_BODY_LIMIT_BYTES=1000000
